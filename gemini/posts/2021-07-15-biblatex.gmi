  year = 2018,
  publisher = {Elsevier {BV}},
  volume = {90},
  pages = {187--199},
  author = {Adole, T. and Dash, J. and Atkinson, P. M.},
  title = {Characterising the land surface phenology of Africa using 500~m {MODIS} {EVI}},
